@startuml
left to right direction
skinparam packageStyle rectangle
skinparam roundcorner 10
skinparam actor {
    BackgroundColor LightCyan
    BorderColor Black
}
skinparam usecase {
    BackgroundColor LightYellow
    BorderColor Black
}

actor "Clinicial/Researcher" as U

rectangle "DrugInsight System" {
  usecase "Inputs Canonical\nDrug Query" as UC1
  usecase "Predicts Risk" as UC2
  usecase "View Explainable\nMechanism" as UC3
  usecase "View Evidence\nScores (DB, PRR, ML)" as UC4
}

U --> UC1
U --> UC2
UC2 .> UC3 : <<include>>
UC2 .> UC4 : <<include>>
@enduml
