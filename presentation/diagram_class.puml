@startuml
skinparam nodesep 70
skinparam ranksep 70
skinparam class {
    BackgroundColor #FCEFB4
    BorderColor Black
    ArrowColor Black
    AttributeIconSize 0
}

class User {
  - user_id : int
  - name : string
  - email : string
  - password : string
  + register()
  + login()
  + submitQuery()
  + viewResults()
}

class DrugQuery {
  - query_id : int
  - drug_a_name : string
  - drug_b_name : string
  - query_date : date
  - query_format : string
  + preprocess()
  + validateCanonical()
}

class DrugInsightModel {
  - model_id : int
  - version : string
  - accuracy : float
  - status : string
  + loadModel()
  + train()
  + engineerFeatures()
  + generatePrediction()
  + evaluateModel()
}

class Admin {
  + manageDataset()
  + trainModel()
  + updateModel()
  + monitorSystem()
}

class FastAPIApp {
  - app_name : string
  - debug_mode : boolean
  + initServer()
  + handlePredict()
}

class Database {
  - connection_id : int
  - host : string
  - database_name : string
  + connect()
  + storeResult()
  + fetchFeatures()
  + closeConnection()
}

User "1 " -right-> " 1" DrugQuery : " uploads"
DrugQuery "1 " -right-> " 1" DrugInsightModel : " processed by"

Admin "1 " -right-* " 1" FastAPIApp : " controls"
FastAPIApp "1 " -right-o " 1" Database : " controls"

User -[hidden]down-> Admin
DrugQuery -[hidden]down-> FastAPIApp

DrugInsightModel "0..1 " -down-> " 1" Database : " generates"

@enduml
